<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.me.stock.mapper.StockOuterMarketIndexInfoMapper">

    <resultMap id="BaseResultMap" type="com.me.stock.pojo.entity.StockOuterMarketIndexInfo">
            <id property="id" column="id" />
            <result property="marketCode" column="market_code" />
            <result property="marketName" column="market_name" />
            <result property="curPoint" column="cur_point" />
            <result property="updown" column="updown" />
            <result property="rose" column="rose" />
            <result property="curTime" column="cur_time" />
    </resultMap>

    <resultMap id="ExternalIndexMap" type="com.me.stock.pojo.domain.ExternalIndexDomain">
        <!-- 将market_name映射到marketName -->
        <result column="market_name" property="name"/>
        <result column="cur_point" property="curPoint"/>
        <result column="updown" property="upDown"/>
        <result column="rose" property="rose"/>
        <result column="cur_time" property="curTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,market_code,market_name,cur_point,updown,rose,
        cur_time
    </sql>

    <select id="selectByPrimaryKey" parameterType="java.lang.Long" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from stock_outer_market_index_info
        where  id = #{id} 
    </select>

    <select id="getExternalIndex" resultMap="ExternalIndexMap">
        SELECT market_name, cur_point, updown, rose, cur_time
        FROM stock_outer_market_index_info
        ORDER BY cur_time DESC, cur_point DESC
        LIMIT 4
    </select>

    <delete id="deleteByPrimaryKey" parameterType="java.lang.Long">
        delete from stock_outer_market_index_info
        where  id = #{id} 
    </delete>
    <insert id="insert" keyColumn="id" keyProperty="id" parameterType="com.me.stock.pojo.entity.StockOuterMarketIndexInfo" useGeneratedKeys="true">
        insert into stock_outer_market_index_info
        ( id,market_code,market_name,cur_point,updown,rose,
        cur_time)
        values (#{id},#{marketCode},#{marketName},#{curPoint},#{updown},#{rose},
        #{curTime})
    </insert>
    <insert id="insertSelective" keyColumn="id" keyProperty="id" parameterType="com.me.stock.pojo.entity.StockOuterMarketIndexInfo" useGeneratedKeys="true">
        insert into stock_outer_market_index_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
                <if test="id != null">id,</if>
                <if test="marketCode != null">market_code,</if>
                <if test="marketName != null">market_name,</if>
                <if test="curPoint != null">cur_point,</if>
                <if test="updown != null">updown,</if>
                <if test="rose != null">rose,</if>
                <if test="curTime != null">cur_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
                <if test="id != null">#{id},</if>
                <if test="marketCode != null">#{marketCode},</if>
                <if test="marketName != null">#{marketName},</if>
                <if test="curPoint != null">#{curPoint},</if>
                <if test="updown != null">#{updown},</if>
                <if test="rose != null">#{rose},</if>
                <if test="curTime != null">#{curTime},</if>
        </trim>
    </insert>
    <insert id="insertBatch">
        insert into stock_outer_market_index_info
        (id, market_code, market_name, cur_point, updown, rose, cur_time)
        values
        <foreach collection="entities" item="entity" separator=",">
            (#{entity.id},#{entity.marketCode},#{entity.marketName},#{entity.curPoint}
            ,#{entity.updown},#{entity.rose},#{entity.curTime})
        </foreach>
        ON DUPLICATE KEY UPDATE
        market_name = VALUES(market_name),
        market_code = VALUES(market_code),
        cur_point = VALUES(cur_point),
        updown = VALUES(updown),
        rose = VALUES(rose)
    </insert>
    <update id="updateByPrimaryKeySelective" parameterType="com.me.stock.pojo.entity.StockOuterMarketIndexInfo">
        update stock_outer_market_index_info
        <set>
                <if test="marketCode != null">
                    market_code = #{marketCode},
                </if>
                <if test="marketName != null">
                    market_name = #{marketName},
                </if>
                <if test="curPoint != null">
                    cur_point = #{curPoint},
                </if>
                <if test="updown != null">
                    updown = #{updown},
                </if>
                <if test="rose != null">
                    rose = #{rose},
                </if>
                <if test="curTime != null">
                    cur_time = #{curTime},
                </if>
        </set>
        where   id = #{id} 
    </update>
    <update id="updateByPrimaryKey" parameterType="com.me.stock.pojo.entity.StockOuterMarketIndexInfo">
        update stock_outer_market_index_info
        set 
            market_code =  #{marketCode},
            market_name =  #{marketName},
            cur_point =  #{curPoint},
            updown =  #{updown},
            rose =  #{rose},
            cur_time =  #{curTime}
        where   id = #{id} 
    </update>
</mapper>
